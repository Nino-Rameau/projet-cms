# ─── Domaine public du CMS ───────────────────────────────────────
CMS_DOMAIN=cms.ton-domaine.fr

# ─── MariaDB ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_USER=cms
MYSQL_PASSWORD=change_me_app

# ─── NextAuth ────────────────────────────────────────────────────
# Génère avec : openssl rand -base64 32
NEXTAUTH_SECRET=change_me_secret_32_chars_minimum

# ─── Dev uniquement (non utilisé en prod) ────────────────────────
DEV_DATABASE_URL=mysql://root:change_me_root@localhost:3306/pageblanche
